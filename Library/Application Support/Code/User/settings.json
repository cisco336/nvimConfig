{
  "[*]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[lua]": {
    "editor.defaultFormatter": "yinfei.luahelper",
  },
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 5000,

  // editor
  "editor.fontFamily": "MesloLGL Nerd Font Mono",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.lineHeight": 25,
  "editor.guides.indentation": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.lineNumbers": "on",
  "editor.minimap.autohide": "scroll",
  "editor.wordWrap": "on",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorStyle": "line",
  "editor.cursorBlinking": "expand",
  "css.lint.unknownAtRules": "ignore",

  // Pretier
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.formatOnType": true,
  "prettier.singleQuote": true,
  "prettier.semi": true,

  // Explorer
  "explorer.compactFolders": false,
  "explorer.enableDragAndDrop": true,
  "explorer.enableUndo": true,

  // Terminal
  "terminal.integrated.fontFamily": "MesloLGL Nerd Font Mono",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.lineHeight": 1,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "block",
  "terminal.integrated.cursorWidth": 2,
  "terminal.integrated.fontWeight": "100",
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.defaultProfile.osx": "JavaScript Debug Terminal",
  "application.shellEnvironmentResolutionTimeout": 20,

  "security.workspace.trust.untrustedFiles": "open",
  "luahelper.format.break_after_functiondef_lp": true,
  "luahelper.format.break_after_functioncall_lp": true,
  "luahelper.format.break_after_table_lb": true,
  "luahelper.format.break_before_functioncall_rp": true,
  "luahelper.format.break_before_functiondef_rp": true,
  "git.autofetch": true,
  "editor.accessibilitySupport": "off",
  "workbench.colorTheme": "Sequoia Moonlight",
  "workbench.iconTheme": "catppuccin-perfect-aura",
  "workbench.productIconTheme": "bongocat",
  "[dotenv]": {
    "editor.defaultFormatter": "lumirelle.shell-format-rev",
  },
  "[shellscript]": {
    "editor.defaultFormatter": "lumirelle.shell-format-rev",
  },
  "explorer.confirmDragAndDrop": false,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "search.defaultViewMode": "tree",

  // Workbench
  "workbench.sideBar.location": "right",
  "workbench.activityBar.autoHide": true,
  "workbench.activityBar.compact": true,
  "workbench.statusBar.visible": false,
  "window.commandCenter": false,
  "workbench.layoutControl.enabled": false,
  "json.schemaDownload.enable": false,
}
